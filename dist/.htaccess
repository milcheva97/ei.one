# SPA fallback: serve index.html for all routes handled by the React app
RewriteEngine On

# Strip trailing slashes (e.g. /education/ -> /education) so relative asset paths resolve
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)/$ /$1 [R=301,L]

# Serve existing files and directories as-is
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Everything else falls back to index.html
RewriteRule ^ index.html [L]

# --- Caching ---
# Vite emits hash-named assets (index-<hash>.js/.css): the name changes whenever
# the content changes, so they can be cached forever. index.html must NOT be
# cached, otherwise browsers keep pointing at old asset hashes after a deploy.
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2?|ttf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>
